# shellcheck shell=bash
# camphor host optimized profile (Intel MPI + OpenMP hybrid build)

: "${USE_MODULES:=1}"
: "${MODULES_TO_UNLOAD:=PrgEnvIntel intel-python}"
: "${MODULES_TO_LOAD:=PrgEnvIntel intel/2023.2 intelmpi/2023.2}"

: "${CC:=mpiicc}"
: "${CXX:=mpiicpc}"
: "${FC:=mpiifort}"

CAM_OPT="-ipo -O3 -no-prec-div -xHost -fp-model precise"
CAM_OPT+=" -inline-level=2 -inline-forceinline -inline-factor=300 -no-inline-max-total-size"
CAM_OPT+=" -qopt-report=5 -traceback -mcmodel=medium"

: "${FFLAGS:=${CAM_OPT} -qopenmp -fpp -DUSE_MPI}"
: "${CFLAGS:=${CAM_OPT} -qopenmp}"
: "${CXXFLAGS:=${CAM_OPT} -qopenmp}"
: "${LDFLAGS:=}"
